// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Better Auth core models + owner role field.

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  owner         Owner?

  role String @default("OWNER")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// Owner domain profile linked to Better Auth user (1:1).

model Owner {
  id                 String                  @id @default(cuid())
  userId             String                  @unique
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  gor                Gor?
  subscription       Subscription?
  notifications      OwnerNotification[]
  whatsappSettings              OwnerWhatsAppSettings?
  whatsappMessageLogs           WhatsAppMessageLog[]
  browserNotificationSettings   OwnerBrowserNotificationSettings?
  createdAt                     DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@map("owner")
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  GRACE_PERIOD
  EXPIRED
  CANCELLED
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  ELITE
}

model Subscription {
  id         String                @id @default(cuid())
  ownerId    String                @unique
  owner      Owner                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  plan       SubscriptionPlan      @default(FREE)
  status     SubscriptionStatus    @default(TRIAL)
  startsAt   DateTime              @default(now())
  expiresAt  DateTime?
  graceUntil DateTime?
  payments   SubscriptionPayment[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@map("subscription")
}

enum SubscriptionBillingAction {
  UPGRADE
  RENEW
}

model SubscriptionPayment {
  id                String                    @id @default(cuid())
  subscriptionId    String
  subscription      Subscription              @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount            Int
  status            PaymentStatus             @default(PENDING)
  paymentMethod     PaymentMethod             @default(MIDTRANS)
  targetPlan        SubscriptionPlan
  billingAction     SubscriptionBillingAction
  externalReference String?
  paidAt            DateTime?
  expiresAt         DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([subscriptionId])
  @@index([subscriptionId, status])
  @@index([externalReference])
  @@map("subscription_payment")
}

// GOR (sports venue) — one per owner/user, many courts.

model Gor {
  id             String   @id @default(cuid())
  ownerId        String   @unique
  owner          Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name           String
  slug           String   @unique
  phone          String?
  email          String?
  address        String
  city           String   @default("")
  province       String   @default("")
  description    String?
  logoUrl        String?
  coverImages    String[] @default([])
  timezone       String   @default("Asia/Jakarta")
  currency       String   @default("IDR")
  isActive       Boolean  @default(true)
  bankName             String?
  bankAccountNumber    String?
  bankAccountHolder    String?
  qrisImageUrl         String?
  courts         Court[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("gor")
}

enum SportType {
  BADMINTON
  FUTSAL
  BASKETBALL
  VOLLEYBALL
  TENNIS
  OTHER
}

enum CourtFacility {
  PARKING
  TOILET
  SHOWER
  CHANGING_ROOM
  CAFETERIA
  PRAYER_ROOM
  OTHER
}

model Court {
  id           String          @id @default(cuid())
  gorId        String
  gor          Gor             @relation(fields: [gorId], references: [id], onDelete: Cascade)
  name         String
  sportType    SportType
  description  String?
  imageUrls    String[]        @default([])
  facilities   CourtFacility[] @default([])
  isActive     Boolean         @default(true)
  displayOrder Int             @default(0)
  priceRules       PriceRule[]
  operatingHours   OperatingHours[]
  bookings         Booking[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([gorId])
  @@index([gorId, displayOrder])
  @@index([gorId, isActive])
  @@map("court")
}

// Pricing windows per court — time stored as minute of day (0–1439).

model PriceRule {
  id          String   @id @default(cuid())
  courtId     String
  court       Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  price       Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courtId])
  @@index([courtId, dayOfWeek])
  @@index([courtId, dayOfWeek, isActive])
  @@index([courtId, dayOfWeek, startMinute])
  @@map("price_rule")
}

// Court operating windows — time stored as minute of day (0–1439).

model OperatingHours {
  id          String   @id @default(cuid())
  courtId     String
  court       Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courtId])
  @@index([courtId, dayOfWeek])
  @@index([courtId, dayOfWeek, isActive])
  @@index([courtId, dayOfWeek, startMinute])
  @@map("operating_hours")
}

// Booking foundation — court reservation with denormalized snapshots.

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Booking {
  id                  String        @id @default(cuid())
  courtId             String
  court               Court         @relation(fields: [courtId], references: [id], onDelete: Cascade)
  bookingNumber       String        @unique
  bookingDate         DateTime      @db.Date
  startMinute         Int
  endMinute           Int
  durationMinute      Int
  totalPrice          Int
  status              BookingStatus @default(PENDING)
  expiresAt           DateTime
  gorNameSnapshot     String
  courtNameSnapshot   String
  sportTypeSnapshot   String
  pricePerHourSnapshot Int
  contact             BookingContact?
  payments            Payment[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([courtId, bookingDate])
  @@index([courtId, bookingDate, status])
  @@index([bookingDate, startMinute])
  @@map("booking")
}

model BookingContact {
  id            String  @id @default(cuid())
  bookingId     String  @unique
  booking       Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhone String
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("booking_contact")
}

// Payment foundation — gateway payment attempts per booking.

enum PaymentStatus {
  PENDING
  AWAITING_CONFIRMATION
  PAID
  FAILED
  EXPIRED
  REFUNDED
  REJECTED
}

enum PaymentMethod {
  MIDTRANS
  MANUAL_TRANSFER
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String
  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount            Int
  status            PaymentStatus @default(PENDING)
  method            PaymentMethod @default(MIDTRANS)
  externalReference String?
  paymentUrl        String?
  snapToken         String?
  paidAt            DateTime?
  expiredAt         DateTime?
  customerConfirmedAt DateTime?
  approvedByUserId  String?
  approvedAt        DateTime?
  rejectedByUserId  String?
  rejectedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  invoice           Invoice?
  auditLogs         PaymentConfirmationAuditLog[]

  @@index([bookingId])
  @@index([bookingId, status])
  @@index([externalReference])
  @@index([status, customerConfirmedAt])
  @@map("payment")
}

enum PaymentConfirmationAction {
  CREATED
  CUSTOMER_CONFIRMED
  APPROVED
  REJECTED
  CANCELLED
}

model PaymentConfirmationAuditLog {
  id              String                    @id @default(cuid())
  paymentId       String
  payment         Payment                   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  actorUserId     String?
  action          PaymentConfirmationAction
  fromStatus      PaymentStatus?
  toStatus        PaymentStatus?
  note            String?
  createdAt       DateTime                  @default(now())

  @@index([paymentId])
  @@index([createdAt])
  @@map("payment_confirmation_audit_log")
}

// Invoice foundation — immutable e-nota generated after successful payment.

enum InvoiceStatus {
  GENERATED
  VOID
}

model Invoice {
  id                    String        @id @default(cuid())
  paymentId             String        @unique
  payment               Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceNumber         String        @unique
  bookingNumberSnapshot String
  customerNameSnapshot  String
  customerPhoneSnapshot String
  gorNameSnapshot       String
  courtNameSnapshot     String
  bookingDateSnapshot   DateTime      @db.Date
  startMinuteSnapshot   Int
  endMinuteSnapshot     Int
  totalAmountSnapshot   Int
  status                InvoiceStatus @default(GENERATED)
  generatedAt           DateTime      @default(now())
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([status])
  @@index([generatedAt])
  @@map("invoice")
}

enum NotificationType {
  BOOKING_CREATED
  PAYMENT_AWAITING_CONFIRMATION
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  BOOKING_CANCELLED
  SUBSCRIPTION_EXPIRING
  SUBSCRIPTION_ACTIVATED
}

enum NotificationCategory {
  BOOKING
  PAYMENT
  SYSTEM
}

model OwnerNotification {
  id          String               @id @default(cuid())
  ownerId     String
  owner       Owner                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type        NotificationType
  category    NotificationCategory
  title       String
  description String
  href        String?
  bookingId   String?
  readAt      DateTime?
  createdAt   DateTime             @default(now())

  @@index([ownerId, createdAt(sort: Desc)])
  @@index([ownerId, readAt])
  @@map("owner_notification")
}

enum WhatsAppMessageStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

enum WhatsAppRecipientType {
  OWNER
  CUSTOMER
}

enum WhatsAppMessageType {
  OWNER_NEW_BOOKING
  OWNER_PAYMENT_AWAITING
  OWNER_BOOKING_CANCELLED
  CUSTOMER_BOOKING_CREATED
  CUSTOMER_PAYMENT_APPROVED
  CUSTOMER_PAYMENT_REJECTED
  CUSTOMER_BOOKING_REMINDER
  OWNER_SUBSCRIPTION_ACTIVATED
}

model OwnerWhatsAppSettings {
  id                 String   @id @default(cuid())
  ownerId            String   @unique
  owner              Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  enabled            Boolean  @default(true)
  notifyBooking      Boolean  @default(true)
  notifyPayment      Boolean  @default(true)
  notifyReminder     Boolean  @default(true)
  notifySubscription Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("owner_whatsapp_settings")
}

model WhatsAppMessageLog {
  id               String                @id @default(cuid())
  ownerId          String?
  owner            Owner?                @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  bookingId        String?
  recipientPhone   String
  recipientType    WhatsAppRecipientType
  messageType      WhatsAppMessageType
  messageBody      String                @db.Text
  status           WhatsAppMessageStatus @default(PENDING)
  attemptCount     Int                   @default(0)
  providerName     String?
  providerResponse String?               @db.Text
  errorMessage     String?
  sentAt           DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([bookingId, messageType, status])
  @@index([ownerId, createdAt(sort: Desc)])
  @@index([status, attemptCount])
  @@map("whatsapp_message_log")
}

model OwnerBrowserNotificationSettings {
  id                 String   @id @default(cuid())
  ownerId            String   @unique
  owner              Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  enabled            Boolean  @default(true)
  notifyBooking      Boolean  @default(true)
  notifyPayment      Boolean  @default(true)
  notifyReminder     Boolean  @default(true)
  notifySubscription Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("owner_browser_notification_settings")
}
