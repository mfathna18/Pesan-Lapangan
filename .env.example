# =============================================================================
# PesanLapangan — Environment Variables
# Copy to `.env` for local development. Never commit `.env`.
# Full deployment guide: docs/DEPLOYMENT.md
# =============================================================================

# --- Application (required) ---
# Local: http://localhost:3000
# Production: https://your-domain.com (HTTPS required)
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (required) ---
# Runtime (Vercel/serverless): use Supabase Transaction pooler (port 6543, ?pgbouncer=true)
# Migrations (Prisma CLI): use DIRECT_URL — direct/session connection (port 5432)
# Local PostgreSQL: set DATABASE_URL only; DIRECT_URL is optional.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pesan_lapangan?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/pesan_lapangan?schema=public"

# --- Better Auth (required) ---
# Must match the URL users visit (same host/scheme as NEXT_PUBLIC_APP_URL).
# Secret: generate 32+ random characters; unique per environment.
BETTER_AUTH_SECRET=replace-with-a-secure-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# --- Midtrans (required) ---
# Sandbox keys: https://dashboard.sandbox.midtrans.com → Settings → Access Keys
# Production keys: https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=replace-with-your-midtrans-server-key
MIDTRANS_CLIENT_KEY=replace-with-your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# --- Vercel Cron (required on Vercel) ---
# Vercel sends this value as Bearer token to /api/cron/expire-bookings
# Generate 32+ random characters; unique per environment.
CRON_SECRET=replace-with-a-secure-cron-secret-at-least-32-characters

# --- Optional (build / CI only) ---
# Skip Zod env validation during Docker/CI builds. Do NOT use on Vercel Production.
# SKIP_ENV_VALIDATION=true

# =============================================================================
# Vercel auto-provided (do not set manually)
# =============================================================================
# VERCEL_URL          — deployment hostname (e.g. my-app.vercel.app)
# VERCEL_ENV          — production | preview | development
# Used for preview trusted origins; see docs/DEPLOYMENT.md

# =============================================================================
# Production example (Vercel → Settings → Environment Variables)
# =============================================================================
# NODE_ENV=production
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# DATABASE_URL=postgresql://...@aws-0-....pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://...@aws-0-....pooler.supabase.com:5432/postgres
# BETTER_AUTH_SECRET=<unique-32-plus-character-secret>
# BETTER_AUTH_URL=https://your-domain.com
# MIDTRANS_SERVER_KEY=Mid-server-...
# MIDTRANS_CLIENT_KEY=Mid-client-...
# MIDTRANS_IS_PRODUCTION=true
# CRON_SECRET=<unique-32-plus-character-secret>
