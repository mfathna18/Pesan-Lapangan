# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (PostgreSQL)
# Production (Vercel): use a pooled connection string for runtime.
# Example providers: Neon, Supabase, Vercel Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pesan_lapangan?schema=public"

# Better Auth
# Production: use HTTPS URLs that match your deployed domain exactly.
BETTER_AUTH_SECRET=replace-with-a-secure-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# Midtrans
# Sandbox: MIDTRANS_IS_PRODUCTION=false
# Production: MIDTRANS_IS_PRODUCTION=true and production API keys
MIDTRANS_SERVER_KEY=replace-with-your-midtrans-server-key
MIDTRANS_CLIENT_KEY=replace-with-your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# Optional: skip env validation during Docker builds only
# SKIP_ENV_VALIDATION=true

# ---------------------------------------------------------------------------
# Production example (Vercel)
# ---------------------------------------------------------------------------
# NODE_ENV=production
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# BETTER_AUTH_SECRET=generate-a-unique-32-plus-character-secret
# BETTER_AUTH_URL=https://your-domain.com
# MIDTRANS_SERVER_KEY=your-production-server-key
# MIDTRANS_CLIENT_KEY=your-production-client-key
# MIDTRANS_IS_PRODUCTION=true
